{
   "$schema": "https://cdn.statically.io/gh/nguyenngoclongdev/cdn/main/schema/v11/terminal-keeper.json",
   "theme": "dice",
   "active": "default",
   "activateOnStartup": false,
   "keepExistingTerminals": false,
   "noClear": true,
   "sessions": {
      "default": [
         {
            "autoExecuteCommands": true,
            "cwd": "apps/frontend",
            "icon": "browser",
            "name": "dev:frontend",
            "commands": [
               "pnpm dev"
            ]
         },
         {
            "autoExecuteCommands": true,
            "cwd": "apps/backend",
            "icon": "server",
            "name": "dev:backend",
            "commands": [
               "pnpm dev:nitro"
            ]
         },
         {
            "autoExecuteCommands": true,
            "cwd": "apps/backend",
            "icon": "database",
            "name": "dev:db",
            "commands": [
               "pnpm dev:docker-db"
            ]
         },
         {
            "autoExecuteCommands": true,
            "icon": "eye-watch",
            "name": "db:studio",
            "commands": [
               "pnpm db:studio"
            ]
         }
      ]
   }
}