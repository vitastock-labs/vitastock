# ============================================
# VitaStock Backend Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# Never commit to version control

# ============================================
# Application Configuration
# ============================================
# Environment: development or production
NODE_ENV=development

# Server port (default: 8000)
PORT=8000

# Logging level: debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# ============================================
# Database Configuration
# ============================================
# Development database connection
DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:5433/vitastock

# Production database connection
DATABASE_URL=postgresql://username:password@your-host:5432/vitastock

# Database operation flags
DB_MIGRATING=false
DB_SEEDING=false

# Default password for seeded users (used only during development)
SEED_PASSWORD=password123

# ============================================
# JWT Authentication
# ============================================
# Generate strong secrets using: openssl rand -base64 32
ACCESS_SECRET=your-access-secret-here-min-32-chars
REFRESH_SECRET=your-refresh-secret-here-min-32-chars

# Token expiration times (milliseconds)
ACCESS_JWT_EXPIRES_IN=300000        # 5 minutes
REFRESH_JWT_EXPIRES_IN=900000       # 15 minutes

# ============================================
# Host Configuration
# ============================================
# Development URLs (usually defaults are fine)
BASE_BACKEND_HOST_DEV=http://localhost:8000
BASE_FRONTEND_HOST_DEV=http://localhost:3000

# Production URLs (replace with your actual domain)
BASE_BACKEND_HOST=https://api-vitastock.vercel.app
BASE_FRONTEND_HOST=https://vitastock.vercel.app

# ============================================
# Redis Configuration
# ============================================
# Redis cache for sessions and temporary data
REDIS_CACHE_URL_DEV=redis://localhost:6381
REDIS_CACHE_URL=redis://your-redis-host:6379

# Redis queue for background jobs and email processing
REDIS_QUEUE_URL_DEV=redis://localhost:6382
REDIS_QUEUE_URL=redis://your-redis-host:6380

# ============================================
# Email Service Configuration
# ============================================
EMAIL_USER=your-email-address
EMAIL_USER_DEV=bella.schroeder@ethereal.email
EMAIL_APP_PASSWORD=your-email-app-password
EMAIL_APP_PASSWORD_DEV=RwRhRUYeranPd4caCS
BREVO_API_KEY=your-brevo-api-key

# ============================================
# Docker Configuration (for Docker development)
# ============================================
# These are automatically set in docker-compose.yaml
# DATABASE_URL_DEV=postgresql://postgres:postgres@vitastock-postgres-db:5432/vitastock
# REDIS_CACHE_URL_DEV=redis://vitastock-redis-cache:6379
# REDIS_QUEUE_URL_DEV=redis://vitastock-redis-queue:6379

# ============================================
# Development Notes
# ============================================
# 1. For local development, you can use provided defaults for most URLs
# 2. Generate strong secrets: openssl rand -base64 32
# 3. Never share or commit to version control
# 4. For production, use environment-specific .env files
# 5. Test Redis connections with: redis-cli ping
# 6. Test database connection with: psql $DATABASE_URL_DEV
