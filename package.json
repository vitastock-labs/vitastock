{
	"name": "@vitastock/root",
	"type": "module",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@10.33.3",
	"scripts": {
		"build": "turbo run build",
		"build:backend": "turbo run --filter=@vitastock/backend build",
		"build:backend:nitro": "turbo run --filter=@vitastock/backend build:nitro",
		"build:frontend": "turbo run --filter=@vitastock/frontend build",
		"build:transactional": "turbo run --filter=@vitastock/transactional build",
		"db:generate": "turbo run --filter=@vitastock/db db:generate",
		"db:migrate": "turbo run --filter=@vitastock/db db:migrate",
		"db:push": "turbo run --filter=@vitastock/db db:push",
		"db:seed": "turbo run --filter=@vitastock/db db:seed",
		"db:studio": "turbo run --filter=@vitastock/db db:studio",
		"dev:backend": "turbo run --filter=@vitastock/backend dev",
		"dev:backend:nitro": "turbo run --filter=@vitastock/backend dev:nitro",
		"dev:frontend": "turbo run --filter=@vitastock/frontend dev",
		"dev:transactional": "turbo run --filter=@vitastock/transactional dev",
		"inspect:eslint-config": "pnpx @eslint/config-inspector@latest",
		"lint:eslint": "turbo run lint:eslint",
		"lint:eslint:interactive": "pnpx eslint-interactive@latest . --max-warnings=0 --fix",
		"lint:eslint:root": "eslint . --max-warnings=0",
		"lint:format": "turbo run lint:format",
		"lint:format:root": "prettier --write .",
		"lint:type-check": "turbo run lint:type-check",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "5.8.5",
		"@next/eslint-plugin-next": "^16.2.6",
		"@tanstack/eslint-plugin-query": "5.100.14",
		"@types/node": "25.9.1",
		"@zayne-labs/eslint-config": "0.13.13",
		"@zayne-labs/prettier-config": "0.13.13",
		"eslint": "10.4.0",
		"eslint-plugin-better-tailwindcss": "4.5.0",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-react-refresh": "0.5.2",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.10.2",
		"husky": "9.1.7",
		"lint-staged": "17.0.5",
		"prettier": "3.8.3",
		"prettier-plugin-classnames": "0.10.1",
		"prettier-plugin-merge": "0.10.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"tailwindcss": "4.3.0",
		"turbo": "2.9.14",
		"typescript": "6.0.3"
	}
}
